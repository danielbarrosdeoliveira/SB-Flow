{
  "name": "sb-flow",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "npm run dev -w api",
    "dev:api:seed": "npm run db:seed -w api",
    "dev:landing": "npm run dev -w packages/landing -- --host",
    "dev:agenda": "npm run dev -w packages/agenda -- --host",
    "dev:dashboard": "npm run dev -w packages/dashboard -- --host",
    "build:api": "npm run build -w api",
    "build:landing": "npm run build -w packages/landing",
    "build:agenda": "npm run build -w packages/agenda",
    "build:dashboard": "npm run build -w packages/dashboard",
    "generate:landing": "npm run generate -w packages/landing",
    "lint": "biome check .",
    "lint:fix": "biome check --apply .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "typecheck": "npm run typecheck -w api"
  },
  "workspaces": ["api", "packages/landing", "packages/agenda", "packages/dashboard"],
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
